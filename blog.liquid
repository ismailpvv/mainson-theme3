<div style="max-width:1200px;margin:0 auto;padding:5rem 2.5rem">
  <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;color:#f0ebe3;margin-bottom:3rem">{{ blog.title }}</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:2rem">
    {% for article in blog.articles %}
      <a href="{{ article.url }}" style="display:block;border-bottom:0.5px solid rgba(240,235,227,0.08);padding-bottom:2rem">
        {% if article.image %}
          {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', style: 'width:100%;aspect-ratio:16/9;object-fit:cover;margin-bottom:1rem' }}
        {% endif %}
        <div style="font-size:0.65rem;letter-spacing:3px;text-transform:uppercase;color:#c9a96e;margin-bottom:0.5rem">{{ article.published_at | date: '%B %d, %Y' }}</div>
        <h2 style="font-family:'Playfair Display',serif;font-size:1.3rem;color:#f0ebe3;margin-bottom:0.5rem">{{ article.title }}</h2>
        <p style="font-size:0.82rem;color:#7a756f;line-height:1.7">{{ article.excerpt | strip_html | truncate: 120 }}</p>
      </a>
    {% endfor %}
  </div>
</div>
