<div style="max-width:720px;margin:0 auto;padding:5rem 2.5rem">
  <a href="{{ blog.url }}" style="font-size:0.65rem;letter-spacing:3px;text-transform:uppercase;color:#c9a96e;display:block;margin-bottom:2rem">← {{ blog.title }}</a>
  <div style="font-size:0.65rem;letter-spacing:3px;text-transform:uppercase;color:#4a4540;margin-bottom:1rem">{{ article.published_at | date: '%B %d, %Y' }}</div>
  <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;color:#f0ebe3;margin-bottom:2rem;line-height:1.2">{{ article.title }}</h1>
  {% if article.image %}
    {{ article.image | image_url: width: 900 | image_tag: loading: 'eager', style: 'width:100%;margin-bottom:2rem' }}
  {% endif %}
  <div style="font-size:0.9rem;line-height:1.9;color:#7a756f;font-weight:300">{{ article.content }}</div>
</div>
