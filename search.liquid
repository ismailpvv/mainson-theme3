<div style="max-width:1200px;margin:0 auto;padding:5rem 2.5rem">
  <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;color:#f0ebe3;margin-bottom:2rem">Search</h1>
  <form action="/search" method="get" style="margin-bottom:3rem;display:flex;gap:0">
    <input type="text" name="q" value="{{ search.terms | escape }}" placeholder="Search products..."
      style="flex:1;background:#1a1611;border:0.5px solid rgba(240,235,227,0.08);color:#f0ebe3;padding:1rem 1.5rem;font-family:'Jost',sans-serif;font-size:0.9rem;outline:none">
    <button type="submit" style="background:#c9a96e;color:#0e0e0e;border:none;padding:1rem 2rem;font-family:'Jost',sans-serif;font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;cursor:pointer">Search</button>
  </form>
  {% if search.performed %}
    <p style="font-size:0.8rem;color:#4a4540;margin-bottom:2rem">{{ search.results_count }} results for "{{ search.terms }}"</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.5rem">
      {% for item in search.results %}
        <a href="{{ item.url }}" style="display:block">
          {% if item.featured_image %}
            {{ item.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', style: 'width:100%;aspect-ratio:3/4;object-fit:cover;margin-bottom:0.8rem' }}
          {% endif %}
          <div style="font-size:0.85rem;color:#f0ebe3">{{ item.title }}</div>
          {% if item.price %}
            <div style="font-size:0.85rem;color:#c9a96e;margin-top:0.3rem">{{ item.price | money }}</div>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  {% endif %}
</div>
